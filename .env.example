# REQUIRED: Google Apps Script Web App URL
# Get this after deploying apps-script/code.gs as a Web App in your Google Sheet
APPS_SCRIPT_URL="https://script.google.com/macros/s/AKfycb.../exec"

# ============================================================
# PIN PROTECTION (4-digit access lock)
# ============================================================
# Set a 4-digit (or up to 8-digit) numeric PIN to lock the entire panel
# behind a PIN entry screen. Leave empty/blank to disable (open access).
#
# When set, every visitor must enter this PIN at /login before they can
# view the dashboard or call any API. The PIN is never stored in the
# browser cookie - only a SHA-256 hash of (PIN + salt) is stored.
#
# Example:
APP_PIN="1234"
#
# To change the PIN later: update this env var and redeploy.
# To disable PIN protection: set APP_PIN="" (empty) or remove this line.
# ============================================================

# ============================================================
# WHATSAPP CLOUD API (auto-send + auto-capture replies)
# ============================================================
# Optional. If set, "Generate Messages" will send automatically from
# your business WhatsApp number and supplier replies will be captured
# via webhook. If NOT set, falls back to wa.me manual mode.
#
# Setup (see Settings → WhatsApp tab in the app, or README):
#   1. Create Meta Business account + WhatsApp app
#   2. Add a new phone number (NOT your personal WhatsApp number)
#   3. Get permanent access token + phone number ID
#   4. Create "rate_enquiry" message template, get it approved
#   5. Configure webhook URL: https://your-domain.com/api/whatsapp/webhook
#
# Required for auto-send:
WA_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_BUSINESS_NUMBER=""           # e.g. 919876543210 (E.164, no +)

# Required for webhook (incoming replies):
WA_VERIFY_TOKEN="smartcomp_wh_2026"   # any random string; same in Meta webhook config

# Optional (defaults to rate_enquiry):
WA_TEMPLATE_NAME="rate_enquiry"
# ============================================================

# Optional: Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED="1"

# Optional: Cron secret for auto-enquiry on 1st and 15th of month
# On Vercel: cron runs automatically
# On Render: use external cron to hit POST /api/cron/auto-enquiry with header "Authorization: Bearer YOUR_SECRET"
CRON_SECRET="change-this-to-a-random-string"
