{
  "name": "smartcomp",
  "private": true,
  "version": "9.0.1-servicefix",
  "description": "SmartComp — Sales & Service Panel. Cleaned, performance-tuned build with instant preview, sheet-scoped cache, and the bloated AI/Command/Automation/Poster modules removed.",
  "keywords": [
    "shop management",
    "gst billing",
    "service management",
    "stock",
    "erp",
    "invoicing",
    "quotations"
  ],
  "main": "electron/main.js",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "check": "next build",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron electron/main.js\"",
    "electron:build": "node scripts/build-exe.js",
    "dist:win": "node scripts/build-exe.js --target=win-x64",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint src --ext .ts,.tsx",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tailwindcss/postcss": "^4.3.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel-react": "8.6.0",
    "html-to-image": "^1.11.13",
    "input-otp": "1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "0.487.0",
    "next": "15.5.21",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-resizable-panels": "2.1.7",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.5.21",
    "@types/node": "20.17.6",
    "@types/react": "19.2.17",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.7.0",
    "tailwindcss": "4.1.12",
    "tsx": "^4.23.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.65.0",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": "20.x"
  },
  "allowScripts": {
    "electron@33.4.11": true
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
